{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Serif Headings",
	"styles": {
		"typography": {
			"lineHeight": "1.65"
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--source-serif)",
					"fontWeight": "700",
					"lineHeight": "1.2",
					"letterSpacing": "-0.02em"
				}
			}
		}
	},
	"settings": {
		"typography": {
			"fontFamilies": [
				{
					"slug": "sans",
					"name": "Inter",
					"fontFamily": "Inter, ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, 'Noto Sans'",
					"fontFace": [
						{
							"fontFamily": "\"Inter\"",
							"fontStyle": "normal",
							"fontWeight": "400",
							"src": [
								"file:./assets/fonts/inter/inter-400-normal.woff2"
							],
							"fontDisplay": "swap"
						},
						{
							"fontFamily": "\"Inter\"",
							"fontStyle": "italic",
							"fontWeight": "400",
							"src": [
								"file:./assets/fonts/inter/inter-400-italic.woff2"
							],
							"fontDisplay": "swap"
						},
						{
							"fontFamily": "\"Inter\"",
							"fontStyle": "normal",
							"fontWeight": "500",
							"src": [
								"file:./assets/fonts/inter/inter-500-normal.woff2"
							],
							"fontDisplay": "swap"
						},
						{
							"fontFamily": "\"Inter\"",
							"fontStyle": "italic",
							"fontWeight": "500",
							"src": [
								"file:./assets/fonts/inter/inter-500-italic.woff2"
							],
							"fontDisplay": "swap"
						},
						{
							"fontFamily": "\"Inter\"",
							"fontStyle": "normal",
							"fontWeight": "600",
							"src": [
								"file:./assets/fonts/inter/inter-600-normal.woff2"
							],
							"fontDisplay": "swap"
						},
						{
							"fontFamily": "\"Inter\"",
							"fontStyle": "italic",
							"fontWeight": "600",
							"src": [
								"file:./assets/fonts/inter/inter-600-italic.woff2"
							],
							"fontDisplay": "swap"
						},
						{
							"fontFamily": "\"Inter\"",
							"fontStyle": "normal",
							"fontWeight": "700",
							"src": [
								"file:./assets/fonts/inter/inter-700-normal.woff2"
							],
							"fontDisplay": "swap"
						},
						{
							"fontFamily": "\"Inter\"",
							"fontStyle": "italic",
							"fontWeight": "700",
							"src": [
								"file:./assets/fonts/inter/inter-700-italic.woff2"
							],
							"fontDisplay": "swap"
						}
					]
				},
				{
					"fontFamily": "'Source Serif 4', Georgia, 'Times New Roman', serif",
					"name": "Source Serif 4",
					"slug": "source-serif",
					"fontFace": [
						{
							"fontDisplay": "swap",
							"fontFamily": "'Source Serif 4'",
							"fontStyle": "normal",
							"fontWeight": "700",
							"src": [
								"file:./assets/fonts/source-serif/SourceSerif4-700.woff2"
							]
						}
					]
				}
			]
		}
	}
}
