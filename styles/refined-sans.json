{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Refined Sans",
	"settings": {
		"color": {
			"palette": [
				{
					"slug": "primary",
					"name": "Primary",
					"color": "#E8368C"
				},
				{
					"slug": "surface-base",
					"name": "Surface Base",
					"color": "#FFFFFF"
				},
				{
					"slug": "surface-muted",
					"name": "Surface Muted",
					"color": "#F8FAFC"
				},
				{
					"slug": "surface-subtle",
					"name": "Surface Subtle",
					"color": "#F1F5F9"
				},
				{
					"slug": "surface-subtle-hover",
					"name": "Surface Subtle Hover",
					"color": "#E2E8F0"
				},
				{
					"slug": "border",
					"name": "Border",
					"color": "#E2E8F0"
				},
				{
					"slug": "input-border",
					"name": "Input Border",
					"color": "#CBD5E1"
				},
				{
					"slug": "text-heading",
					"name": "Text Heading",
					"color": "#0F172A"
				},
				{
					"slug": "text-body",
					"name": "Text Body",
					"color": "#475569"
				},
				{
					"slug": "text-muted",
					"name": "Text Muted",
					"color": "#64748B"
				}
			]
		},
		"typography": {
			"fontFamilies": [
				{
					"slug": "sans",
					"name": "Inter",
					"fontFamily": "Inter, ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, 'Noto Sans'",
					"fontFace": [
						{
							"fontFamily": "\"Inter\"",
							"fontStyle": "normal",
							"fontWeight": "400",
							"src": [
								"file:./assets/fonts/inter/inter-400-normal.woff2"
							],
							"fontDisplay": "swap"
						},
						{
							"fontFamily": "\"Inter\"",
							"fontStyle": "italic",
							"fontWeight": "400",
							"src": [
								"file:./assets/fonts/inter/inter-400-italic.woff2"
							],
							"fontDisplay": "swap"
						},
						{
							"fontFamily": "\"Inter\"",
							"fontStyle": "normal",
							"fontWeight": "500",
							"src": [
								"file:./assets/fonts/inter/inter-500-normal.woff2"
							],
							"fontDisplay": "swap"
						},
						{
							"fontFamily": "\"Inter\"",
							"fontStyle": "italic",
							"fontWeight": "500",
							"src": [
								"file:./assets/fonts/inter/inter-500-italic.woff2"
							],
							"fontDisplay": "swap"
						},
						{
							"fontFamily": "\"Inter\"",
							"fontStyle": "normal",
							"fontWeight": "600",
							"src": [
								"file:./assets/fonts/inter/inter-600-normal.woff2"
							],
							"fontDisplay": "swap"
						},
						{
							"fontFamily": "\"Inter\"",
							"fontStyle": "italic",
							"fontWeight": "600",
							"src": [
								"file:./assets/fonts/inter/inter-600-italic.woff2"
							],
							"fontDisplay": "swap"
						},
						{
							"fontFamily": "\"Inter\"",
							"fontStyle": "normal",
							"fontWeight": "700",
							"src": [
								"file:./assets/fonts/inter/inter-700-normal.woff2"
							],
							"fontDisplay": "swap"
						},
						{
							"fontFamily": "\"Inter\"",
							"fontStyle": "italic",
							"fontWeight": "700",
							"src": [
								"file:./assets/fonts/inter/inter-700-italic.woff2"
							],
							"fontDisplay": "swap"
						}
					]
				},
				{
					"fontFamily": "DM Sans, sans-serif",
					"name": "DM Sans",
					"slug": "dm-sans",
					"fontFace": [
						{
							"fontDisplay": "swap",
							"fontFamily": "DM Sans",
							"fontStyle": "normal",
							"fontWeight": "400 800",
							"src": [
								"file:./assets/fonts/dm-sans/DMSans-VariableFont_opsz,wght.woff2"
							]
						}
					]
				}
			]
		}
	},
	"styles": {
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--dm-sans)",
			"fontWeight": "400",
			"lineHeight": "1.6"
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--dm-sans)",
					"fontWeight": "700",
					"lineHeight": "1.2",
					"letterSpacing": "-0.015em"
				}
			}
		}
	}
}
